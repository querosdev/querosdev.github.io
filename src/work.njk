---
permalink: "/work.html"
title: "Nikodem Kustusz Studio — Realizacje i live proof"
description: "Realizacje: UndergroundGym.pl (publiczny URL), PrimeGym Rumia (koncepcja), NineSmith Sudoku (mój projekt, prywatne repo), Trading Workstation (dashboard systemowy)."
canonical: "https://querosdev.github.io/work.html"
ogTitle: "Realizacje — Nikodem Kustusz Studio"
ogDescription: "Strony, aplikacje i systemy: od live business website po aplikację mobilną i dashboard operacyjny."
bodyClass: "page-work"
---
{% extends "base.njk" %}

{% block head %}{% raw %}
<style>
    .preview-frame {
      width: 100%;
      aspect-ratio: 16/9;
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,.08);
      overflow: hidden;
      position: relative;
      background: #0f1114;
      margin: 0 0 18px;
    }
    .preview-frame svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .work-tags {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }
    .tag-status {
      display: inline-flex;
      align-items: center;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: .76rem;
      font-weight: 800;
      letter-spacing: .05em;
      text-transform: uppercase;
    }
    .tag-live   { background: rgba(52,211,153,.14); color: #34d399; border: 1px solid rgba(52,211,153,.28); }
    .tag-wip    { background: rgba(205,168,93,.14);  color: #cda85d; border: 1px solid rgba(205,168,93,.28); }
    .tag-own    { background: rgba(139,92,246,.14);  color: #a78bfa; border: 1px solid rgba(139,92,246,.28); }
    .tag-sys    { background: rgba(99,170,255,.14);  color: #93c5fd; border: 1px solid rgba(99,170,255,.28); }
    .tag-cat {
      display: inline-flex;
      align-items: center;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: .76rem;
      font-weight: 700;
      color: rgba(242,241,238,.55);
      border: 1px solid rgba(255,255,255,.08);
    }

    .work-feature {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(300px, .8fr);
      gap: clamp(20px, 4vw, 40px);
      align-items: center;
    }
    @media (max-width: 860px) {
      .work-feature { grid-template-columns: 1fr; }
    }
    .work-feature-media {
      position: relative;
      min-height: 340px;
      border-radius: 28px;
      overflow: hidden;
      background: radial-gradient(440px 300px at 90% 8%, rgba(205,168,93,.16), transparent 62%),
                  rgba(255,255,255,.025);
      border: 1px solid rgba(255,255,255,.08);
      box-shadow: 0 28px 70px rgba(0,0,0,.32);
    }
    .work-feature-desktop {
      width: 100%; height: 100%; min-height: inherit;
      object-fit: cover; object-position: top left; opacity: .92;
    }
    .work-feature-mobile {
      position: absolute; right: 18px; bottom: 18px;
      width: min(170px, 28%); max-height: 72%;
      object-fit: cover; object-position: top center;
      border: 1px solid rgba(255,255,255,.14);
      border-radius: 20px;
      box-shadow: 0 24px 54px rgba(0,0,0,.44);
    }
    .work-feature-copy { display: grid; gap: 14px; }
    .work-feature-copy .sub { margin-top: 0; }
    .proof-list { margin: 10px 0 0; padding-left: 18px; color: rgba(242,241,238,.72); }
    .proof-list li { margin: 7px 0; }

    .btn.disabled {
      opacity: .38;
      pointer-events: none;
      cursor: default;
    }

    .grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 18px; }
    @media (max-width: 700px) { .grid-2 { grid-template-columns: 1fr; } }

    .preview-frame img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      object-position: top center;
    }
    .preview-frame.is-web {
      background:
        radial-gradient(420px 260px at 78% 8%, rgba(205,168,93,.14), transparent 64%),
        #0b0c0e;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.05);
    }
    .preview-label {
      position: absolute;
      right: 14px;
      bottom: 14px;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      min-height: 28px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(11,12,14,.72);
      border: 1px solid rgba(205,168,93,.38);
      color: #e6c97a;
      font-size: .72rem;
      font-weight: 900;
      letter-spacing: .08em;
      text-transform: uppercase;
      backdrop-filter: blur(12px);
    }
    .proof-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 14px;
    }
    .sudoku-showcase {
      display: grid;
      grid-template-columns: minmax(0, .9fr) minmax(0, 1.12fr) minmax(0, .9fr);
      align-items: end;
      gap: clamp(8px, 1.5vw, 16px);
      padding: clamp(16px, 2.5vw, 28px) clamp(18px, 3vw, 34px) 0;
      background:
        radial-gradient(260px 180px at 52% 40%, rgba(205,168,93,.16), transparent 66%),
        linear-gradient(135deg, rgba(255,255,255,.03), rgba(255,255,255,.01)),
        #0f1114;
    }
    .phone-shot {
      height: 86%;
      min-height: 0;
      overflow: hidden;
      border-radius: 22px 22px 0 0;
      background: #111318;
      border: 1px solid rgba(205,168,93,.22);
      box-shadow: 0 18px 48px rgba(0,0,0,.35);
    }
    .phone-shot.main {
      height: 105%;
      z-index: 1;
      transform: translateY(10px);
      border-color: rgba(205,168,93,.38);
    }
    .phone-shot.side {
      transform: translateY(22px);
      opacity: .88;
    }
    .phone-shot.muted {
      opacity: .68;
    }
    .phone-shot img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      object-position: top center;
    }
    @media (max-width: 520px) {
      .sudoku-showcase {
        grid-template-columns: .82fr 1.16fr;
      }
      .phone-shot.muted { display: none; }
    }
  </style>
{% endraw %}{% endblock %}

{% block content %}{% raw %}
<main class="page">
  <div class="container">
<div class="title reveal">

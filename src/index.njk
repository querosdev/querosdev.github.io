---
permalink: "/index.html"
title: "Nikodem Kustusz Studio — Strony, panele i lead flow"
description: "Portfolio Nikodema Kustusza: UndergroundGym.pl (live), koncepcja PrimeGym Rumia, prywatny projekt NineSmith Sudoku oraz wewnętrzne systemy i dashboardy."
canonical: "https://querosdev.github.io/"
ogTitle: "Nikodem Kustusz Studio — strony, panele i lead flow"
ogDescription: "Wybrane realizacje: live strona klienta, koncepcja strony fitness, prywatny projekt mobilny i interfejsy systemów wewnętrznych."
bodyClass: "page-home"
---
{% extends "base.njk" %}

{% block head %}{% raw %}
<style>
    .home-hero-clean {
      display: grid;
      grid-template-columns: minmax(0, .9fr) minmax(420px, 1.1fr);
      gap: clamp(28px, 5vw, 72px);
      align-items: center;
      padding: clamp(44px, 8vw, 96px) 0 clamp(28px, 6vw, 64px);
    }

    @media (max-width: 940px) {
      .home-hero-clean { grid-template-columns: 1fr; }
    }

    .home-eyebrow-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }

    .home-proof-pill {
      display: inline-flex;
      width: fit-content;
      align-items: center;
      gap: 6px;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.09);
      color: rgba(242,241,238,.68);
      font-size: .78rem;
      font-weight: 800;
      letter-spacing: .03em;
    }

    .home-proof-pill.gold {
      color: #e6c97a;
      background: rgba(205,168,93,.12);
      border-color: rgba(205,168,93,.34);
    }

    .home-proof-pill.green {
      color: #34d399;
      background: rgba(52,211,153,.10);
      border-color: rgba(52,211,153,.28);
    }

    .home-hero-copy {
      max-width: 700px;
    }

    .home-hero-copy .h1 {
      max-width: 760px;
    }

    .home-hero-copy .sub {
      max-width: 620px;
    }

    .home-hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 26px;
    }

    .home-proof-grid {
      display: grid;
      gap: 14px;
      margin-top: 28px;
      max-width: 680px;
    }

    .home-proof-row {
      display: grid;
      grid-template-columns: 118px 1fr;
      gap: 14px;
      align-items: baseline;
      padding-top: 14px;
      border-top: 1px solid rgba(255,255,255,.08);
    }

    .home-proof-row b {
      color: #e6c97a;
      font-size: .78rem;
      letter-spacing: .10em;
      text-transform: uppercase;
    }

    .home-proof-row span {
      color: rgba(242,241,238,.66);
      line-height: 1.55;
    }

    .home-trust-strip {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 18px;
      max-width: 680px;
    }

    .home-trust-item {
      padding: 12px 13px;
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 16px;
      background: rgba(255,255,255,.025);
    }

    .home-trust-item b {
      display: block;
      margin-bottom: 4px;
      color: rgba(242,241,238,.9);
      font-size: .82rem;
    }

    .home-trust-item span {
      color: rgba(242,241,238,.58);
      font-size: .82rem;
      line-height: 1.4;
    }

    @media (max-width: 620px) {
      .home-proof-row { grid-template-columns: 1fr; gap: 5px; }
      .home-trust-strip { grid-template-columns: 1fr; }
    }

    .home-hero-showcase {
      position: relative;
      min-height: 500px;
      display: grid;
      align-items: center;
    }

    @media (max-width: 940px) {
      .home-hero-showcase { min-height: 0; }
    }

    .home-showcase-frame {
      position: relative;
      overflow: hidden;
      border-radius: 30px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.025);
      box-shadow: 0 34px 90px rgba(0,0,0,.36);
    }

    .home-showcase-frame.primary {
      aspect-ratio: 16 / 10;
    }

    .home-showcase-frame img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top center;
      opacity: .94;
    }

    .home-showcase-bar {
      position: absolute;
      z-index: 2;
      top: 14px;
      left: 14px;
      right: 14px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      pointer-events: none;
    }

    .home-showcase-label {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(5,6,8,.74);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,.10);
      color: rgba(242,241,238,.74);
      font-size: .74rem;
      font-weight: 900;
      letter-spacing: .06em;
      text-transform: uppercase;
    }

    .home-showcase-label.gold {
      color: #e6c97a;
      border-color: rgba(205,168,93,.35);
    }

    .home-showcase-stack {
      position: absolute;
      width: min(250px, 38%);
      right: -22px;
      bottom: -34px;
      display: grid;
      gap: 12px;
    }

    @media (max-width: 940px) {
      .home-showcase-stack {
        position: static;
        width: auto;
        grid-template-columns: 1fr 1fr;
        margin-top: 14px;
      }
    }

    @media (max-width: 620px) {
      .home-showcase-stack { grid-template-columns: 1fr; }
    }

    .home-mini-case {
      overflow: hidden;
      border-radius: 22px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.035);
      box-shadow: 0 24px 54px rgba(0,0,0,.30);
    }

    .home-mini-case img {
      width: 100%;
      height: 156px;
      object-fit: cover;
      object-position: top center;
      display: block;
      opacity: .92;
    }

    .home-mini-case .mini-copy {
      padding: 12px 14px 14px;
      display: grid;
      gap: 4px;
    }

    .home-mini-case strong {
      color: rgba(242,241,238,.92);
      font-size: .95rem;
    }

    .home-mini-case span {
      color: rgba(242,241,238,.55);
      font-size: .78rem;
      line-height: 1.4;
    }

    .home-about-wrap {
      max-width: 720px;
    }

    .home-section-title-row {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      align-items: end;
      margin-bottom: 22px;
    }

    @media (max-width: 720px) {
      .home-section-title-row { align-items: start; flex-direction: column; }
    }

    .home-work-list {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
    }

    @media (max-width: 1060px) {
      .home-work-list { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @media (max-width: 620px) {
      .home-work-list { grid-template-columns: 1fr; }
    }

    .home-work-tile {
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 24px;
      background: rgba(255,255,255,.025);
      overflow: hidden;
      min-height: 100%;
      display: grid;
      grid-template-rows: auto 1fr;
      transition: transform .2s ease, border-color .2s ease, background .2s ease;
    }

    .home-work-tile:hover {
      transform: translateY(-2px);
      border-color: rgba(205,168,93,.22);
      background: rgba(255,255,255,.035);
    }

    .home-work-tile-media {
      aspect-ratio: 16 / 10;
      background: #0d1117;
      border-bottom: 1px solid rgba(255,255,255,.06);
    }

    .home-work-tile-media img,
    .home-work-tile-media svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .home-work-tile-media img {
      object-fit: cover;
      object-position: top center;
    }

    .home-work-tile-body {
      padding: 16px;
      display: grid;
      gap: 10px;
    }

    .home-work-tile-body h3 {
      margin: 0;
    }

    .home-work-tile-body p {
      margin: 0;
      color: rgba(242,241,238,.62);
      line-height: 1.55;
      font-size: .95rem;
    }

    .home-tile-meta {
      color: #e6c97a;
      font-size: .75rem;
      font-weight: 900;
      letter-spacing: .10em;
      text-transform: uppercase;
    }

    .home-system-svg text {
      font-family: var(--font-sans);
    }

    .page-home .section-cta {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 24px;
    }

    .page-home .section-cta .btn {
      width: auto !important;
      max-width: none;
      flex: 0 0 auto !important;
    }

  </style>
{% endraw %}{% endblock %}

{% block content %}{% raw %}
<main class="page">
  <div class="container">
    <section class="home-hero-clean">
      <div class="home-hero-copy reveal" data-reveal-order="2">
        <div class="hero-identity">
          <span class="hero-identity-mark" aria-hidden="true"></span>
          <span class="hero-identity-text">
            <strong>Nikodem Kustusz</strong>
            <span data-i18n="identity_role">Niezależne studio — web i systemy</span>
          </span>
        </div>
        <div class="home-eyebrow-row">
          <span class="home-proof-pill green" data-i18n="hero_pill_1">Publiczny case</span>
          <span class="home-proof-pill gold" data-i18n="hero_pill_2">Jasny zakres</span>
          <span class="home-proof-pill" data-i18n="hero_pill_3">Web + systemy</span>
        </div>

        <h1 class="h1" data-i18n="home_h1">Projektuję premium strony, interfejsy i systemy dla marek, które mają wyglądać ostrzej i działać konkretniej.</h1>
        <p class="sub" data-i18n="home_p">Skupione studio jednej osoby: kierunek wizualny, frontend i logika produktu w jednym miejscu — od pozycjonowania oferty po wdrożenie i polish.</p>

        <div class="home-hero-actions">
          <a class="btn primary" data-book href="https://app.cal.eu/quero/15min" data-i18n="book_call">Umów call</a>
          <a class="btn" href="./work.html" data-i18n="home_cta_work">Zobacz realizacje</a>
        </div>

        <div class="home-proof-grid">
          <div class="home-proof-row">
            <b data-i18n="proof_a_label">Web</b>
            <span data-i18n="proof_a_text">Strony firmowe z ofertą, CTA, lokalnym SEO i wdrożeniem.</span>
          </div>
          <div class="home-proof-row">
            <b data-i18n="proof_b_label">Produkt</b>
            <span data-i18n="proof_b_text">Aplikacje i prototypy pokazujące UX, logikę i assety brandowe.</span>
          </div>
          <div class="home-proof-row">
            <b data-i18n="proof_c_label">Proces</b>
            <span data-i18n="proof_c_text">Dashboardy i flow pracy projektowane pod porządek, status i decyzje.</span>
          </div>
        </div>
        <div class="home-trust-strip" aria-label="Standard współpracy">
          <div class="home-trust-item">
            <b data-i18n="trust_1_title">Product-level polish</b>
            <span data-i18n="trust_1_text">Jakość na poziomie produktu, nie szablonu.</span>
          </div>
          <div class="home-trust-item">
            <b data-i18n="trust_2_title">System, nie losowe strony</b>
            <span data-i18n="trust_2_text">Pozycjonowanie, interfejs i ścieżka konwersji.</span>
          </div>
          <div class="home-trust-item">
            <b data-i18n="trust_3_title">Proof over claims</b>
            <span data-i18n="trust_3_text">Pokazuję proces i output, nie obietnice.</span>
          </div>
        </div>
      </div>

      <div class="home-hero-showcase reveal" data-reveal-order="3">
        <div class="home-showcase-frame primary">
          <div class="home-showcase-bar">
            <span class="home-showcase-label gold">UndergroundGym.pl</span>
            <span class="home-showcase-label" data-i18n="status_live">Live website</span>
          </div>
          <img src="./assets/work/undergroundgym-clean-desktop.png" alt="UndergroundGym.pl live website screenshot" loading="eager" width="1440" height="1000">
        </div>

        <div class="home-showcase-stack">
          <div class="home-mini-case">
            <img src="./assets/work/primegym-rumia-desktop.webp" alt="PrimeGym Rumia website concept screenshot" loading="lazy" width="1920" height="1080">
            <div class="mini-copy">
              <strong>PrimeGym Rumia</strong>
              <span data-i18n="mini_prime">Koncepcja / fitness lifestyle</span>
            </div>
          </div>

          <div class="home-mini-case">
            <img src="./assets/work/sudoku-premium-home.webp" alt="NineSmith Sudoku mobile app screenshot" loading="lazy" width="900" height="1800">
            <div class="mini-copy">
              <strong>NineSmith Sudoku</strong>
              <span data-i18n="mini_sudoku">Mój projekt / prywatne repo</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section class="section proof-spotlight" id="proof">
      <div class="proof-visual reveal" data-reveal-order="4">
        <img class="proof-desktop" src="./assets/work/undergroundgym-clean-desktop.png" alt="Zrzut ekranu strony UndergroundGym.pl na desktopie" loading="lazy" width="1440" height="1000">
        <img class="proof-phone" src="./assets/work/undergroundgym-clean-mobile.png" alt="Mobilny widok strony UndergroundGym.pl" loading="lazy" width="390" height="844">

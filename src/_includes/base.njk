<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://app.cal.eu; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https:; connect-src 'self' https://app.cal.eu https://api.cal.com https://cal.com; frame-src https://app.cal.eu https://cal.com; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <script>
    /* Anti-FOUC language bootstrap — mirrors getLang() in script.js.
       Resolves language before first paint and cloaks text only when it
       differs from the Polish markup, so EN visitors don't see a PL flash. */
    (function () {
      try {
        var q = new URLSearchParams(location.search).get("lang");
        var ls = null; try { ls = localStorage.getItem("lang"); } catch (e) {}
        var nav = (navigator.language || "").toLowerCase();
        var lang = (q === "en" || q === "pl") ? q
                 : (ls === "en" || ls === "pl") ? ls
                 : nav.indexOf("en") === 0 ? "en" : "pl";
        var el = document.documentElement;
        el.setAttribute("lang", lang);
        if (lang !== "pl") {
          el.classList.add("i18n-pending");
          /* Failsafe: never leave text hidden if the main script fails to load. */
          setTimeout(function () { el.classList.remove("i18n-pending"); }, 1500);
        }
      } catch (e) {}
    })();
  </script>
  <meta name="theme-color" content="#0b0c0e" />
  <link rel="icon" href="./assets/brand/favicon.svg" type="image/svg+xml" />
  <link rel="canonical" href="{{ canonical }}" />
  <link rel="stylesheet" href="./style.css" />
  <title>{{ title }}</title>
  <meta name="description" content="{{ description }}" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Nikodem Kustusz Studio" />
  <meta property="og:title" content="{{ ogTitle }}" />
  <meta property="og:description" content="{{ ogDescription }}" />
  <meta property="og:url" content="{{ canonical }}" />
  <meta property="og:image" content="https://querosdev.github.io/assets/brand/og-image.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ ogTitle }}" />
  <meta name="twitter:description" content="{{ ogDescription }}" />
  <meta name="twitter:image" content="https://querosdev.github.io/assets/brand/og-image.png" />
{% block head %}{% endblock %}
</head>
<body class="{{ bodyClass }}">
<header class="nav reveal">
  <div class="container nav-inner">
    <a class="brand" href="./index.html" aria-label="Home">
      <span class="mark" aria-hidden="true"></span>
      <span class="name" data-i18n="site_name">Nikodem Kustusz Studio</span>
      <span class="role" data-i18n="hero_kicker">Partner dla firm</span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      <a href="./index.html" data-nav="home" data-i18n="nav_home">Start</a>
      <a href="./work.html" data-nav="work" data-i18n="nav_work">Realizacje</a>
      <a href="./services.html" data-nav="services" data-i18n="nav_services">Usługi</a>
      <a href="./about.html" data-nav="about" data-i18n="nav_about">O mnie</a>
      <a href="./contact.html" data-nav="contact" data-i18n="nav_contact">Kontakt</a>
    </nav>

    <div class="nav-actions">
      <div class="lang" role="group" aria-label="Language">
        <button id="langPL" type="button" aria-pressed="true">PL</button>
        <button id="langEN" type="button" aria-pressed="false">EN</button>
      </div>
      <a class="btn primary" data-book href="https://app.cal.eu/quero/15min" data-i18n="book_call">Umów call</a>
      <button class="nav-toggle" id="navToggle" type="button" aria-label="Otwórz menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="nav-backdrop" id="navBackdrop" aria-hidden="true"></div>
  <nav class="mobile-menu" id="mobile-menu" role="navigation" aria-label="Nawigacja główna">
    <div class="mobile-links">
      <a href="./index.html" data-nav-mobile="home" data-i18n="nav_home">Start</a>
      <a href="./work.html" data-nav-mobile="work" data-i18n="nav_work">Realizacje</a>
      <a href="./services.html" data-nav-mobile="services" data-i18n="nav_services">Usługi</a>
      <a href="./about.html" data-nav-mobile="about" data-i18n="nav_about">O mnie</a>
      <a href="./contact.html" data-nav-mobile="contact" data-i18n="nav_contact">Kontakt</a>
      <a class="mobile-menu-secondary" href="./privacy.html" data-nav-mobile="privacy" data-i18n="footer_privacy">Polityka prywatności</a>
      <a class="mobile-menu-secondary" href="./legal.html" data-nav-mobile="legal" data-i18n="footer_legal">Prawa autorskie</a>
      <a class="mobile-menu-cta btn primary" data-book href="https://app.cal.eu/quero/15min" data-i18n="book_call">Umów call</a>
    </div>
  </nav>
</header>

{% block content %}{% endblock %}

<footer class="footer">
  <div class="container footer-inner">
    <div class="claim" data-i18n="footer_claim">Strony, panele i landing pages z jasnym zakresem, testami i wdrożeniem.</div>
    <div class="mini">
      <a href="./contact.html" data-i18n="email_short">E-mail</a>
      <a href="./privacy.html" data-nav="privacy" data-i18n="footer_privacy">Polityka prywatności</a>
      <a href="./legal.html" data-nav="legal" data-i18n="footer_legal">Prawa autorskie</a>
      <a href="https://github.com/querosdev" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://www.linkedin.com/in/nikodem-kustusz-031ba1335/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    </div>
    <div class="copyright">© <span data-year></span> Nikodem Kustusz — <span data-i18n="footer_rights">Wszelkie prawa zastrzeżone.</span></div>
  </div>
</footer>
<script src="./script.js"></script>
{% block scripts %}{% endblock %}
</body>
</html>

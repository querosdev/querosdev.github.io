<div class="grid-2">
  <article class="case-panel work-card reveal" data-cat="web,mkt">
    <figure class="case-thumb">
      <img src="./assets/work/undergroundgym-clean-desktop.png" alt="Desktopowy widok strony UndergroundGym.pl" loading="lazy" width="1440" height="1000">
    </figure>
    <div class="case-marker">01</div>
    <div class="row">
      <div>
        <h3 data-i18n="work_1_title">UndergroundGym.pl — strona klubowa</h3>
        <div class="role"><span data-i18n="work_role_label">Rola:</span> <span data-i18n="work_1_role">UX + frontend + wdrożenie</span></div>
      </div>
      <div class="meta" data-i18n="work_1_meta">Fitness / live site</div>
    </div>
    <p class="p work-desc" data-i18n="work_1_desc">Publiczna strona siłowni 24/7 z ofertą, cennikiem, opiniami, formularzem wejścia próbnego i kontaktem.</p>
    <div class="stack">
      <span class="pill">HTML/CSS</span><span class="pill">JS</span><span class="pill">Responsive</span><span class="pill">SEO</span>
    </div>
    <div class="metricline"><span data-i18n="kpi_label">Dowód:</span> <b data-i18n="work_1_metric">live site</b><span data-i18n="work_1_metric_tail"> / realny klient</span></div>
    <div class="inline-actions">
      <a class="btn primary" href="https://undergroundgym.pl/" target="_blank" rel="noopener noreferrer" data-i18n="proof_visit">Otwórz live site</a>
    </div>
  </article>

  <article class="case-panel work-card reveal" data-cat="web,mkt">
    <div class="case-marker">02</div>
    <div class="row">
      <div>
        <h3 data-i18n="work_2_title">Landing sprzedażowy — prototyp</h3>
        <div class="role"><span data-i18n="work_role_label">Rola:</span> <span data-i18n="work_2_role">UI/UX + copy + tracking</span></div>
      </div>
      <div class="meta" data-i18n="work_2_meta">Lead gen / pattern</div>
    </div>
    <p class="p work-desc" data-i18n="work_2_desc">Strona pod kampanię z trackingiem i optymalizacją konwersji.</p>
    <div class="stack">
      <span class="pill">HTML/CSS</span><span class="pill">JS</span><span class="pill">SEO</span><span class="pill">Tracking</span>
    </div>
    <div class="metricline"><span data-i18n="kpi_label">Dowód:</span> <b data-i18n="work_2_metric">prototyp</b><span data-i18n="work_2_metric_tail"> / landing flow</span></div>
  </article>

  <article class="case-panel work-card reveal" data-cat="admin">
    <div class="case-marker">03</div>
    <div class="row">
      <div>
        <h3 data-i18n="work_3_title">Panel operacyjny — prototyp</h3>
        <div class="role"><span data-i18n="work_role_label">Rola:</span> <span data-i18n="work_3_role">Dashboard + role/permissions</span></div>
      </div>
      <div class="meta" data-i18n="work_3_meta">Ops / admin pattern</div>
    </div>
    <p class="p work-desc" data-i18n="work_3_desc">Usprawnienie procesu: role, widoki, raporty, integracje.</p>
    <div class="stack">
      <span class="pill">PHP</span><span class="pill">MySQL</span><span class="pill">Auth</span><span class="pill">RBAC</span>
    </div>
    <div class="metricline"><span data-i18n="kpi_label">Dowód:</span> <b data-i18n="work_3_metric">prototyp</b><span data-i18n="work_3_metric_tail"> / role i raporty</span></div>
  </article>

  <article class="case-panel work-card reveal" data-cat="web">
    <div class="case-marker">04</div>
    <div class="row">
      <div>
        <h3 data-i18n="work_4_title">Strona firmowa — prototyp multi-page</h3>
        <div class="role"><span data-i18n="work_role_label">Rola:</span> <span data-i18n="work_4_role">Design system + wdrożenie</span></div>
      </div>
      <div class="meta" data-i18n="work_4_meta">Brand / layout system</div>
    </div>
    <p class="p work-desc" data-i18n="work_4_desc">Premium layout, performance, SEO i spójne komponenty.</p>
    <div class="stack">
      <span class="pill">Responsive</span><span class="pill">Performance</span><span class="pill">SEO</span>
    </div>
    <div class="metricline"><span data-i18n="kpi_label">Dowód:</span> <b data-i18n="work_4_metric">prototyp</b><span data-i18n="work_4_metric_tail"></span></div>
  </article>
